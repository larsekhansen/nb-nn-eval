# API keys for closed-source models.
# Copy this file to .env and fill in the keys you want to use.
# Models without keys will show an error when you try to load them —
# that's fine, just don't select them in the UI.

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Apertium APY server URL (if not using default localhost:2737).
# APERTIUM_URL=http://localhost:2737
